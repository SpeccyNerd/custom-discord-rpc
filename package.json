{
  "name": "speccy-rpc",
  "version": "1.0.0",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },

  "dependencies": {
    "discord-rpc": "^4.0.1"
  },

  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },

  "build": {
    "appId": "com.speccynerd.rpc",
    "productName": "Speccy RPC",

     "artifactName": "Speccy RPC Installer.${ext}",

    "win": {
      "target": "nsis",
      "icon": "renderer/assets/avatar.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Speccy RPC",
      "installerIcon": "renderer/assets/installicon.ico",
      "installerHeaderIcon": "renderer/assets/installicon.ico",
      "uninstallerIcon": "renderer/assets/uninstallicon.ico",
      "displayLanguageSelector": true,
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true
    }
  }
}
